**/LightsailDefaultKey*.pem
**/application-local.yaml
**/application-secrets.yaml
**/.env
**/.env.local
**/.env.*.local

# ========================
# Frontend (Next.js)
# ========================
**/node_modules/
**/.next/
**/out/
**/.vercel/

# ========================
# Backend (Spring Boot / Gradle)
# ========================
**/.gradle/
**/build/
!**/src/main/**/build/
!**/src/test/**/build/
**/gradle.properties
**/out/
!**/src/main/**/out/
!**/src/test/**/out/

# ========================
# IDE
# ========================
.idea/
**/*.iws
**/*.iml
**/*.ipr
.vscode/
.kotlin/

