# 백엔드 서버 주소 (기본값: http://localhost:8080)
NEXT_PUBLIC_API_URL=http://localhost:8080

# (선택, 서버 전용) /api/pickty-image 가 먼저 시도하는 R2 커스텀 도메인. 비우면 https://img.pickty.app
# PICKTY_IMAGE_PUBLIC_BASE=https://img.pickty.app

# (선택) img.pickty.app 이 403(ORB·핫링크)일 때, R2 대시보드의 pub-xxxxxxxx.r2.dev 같은 Public URL 베이스(끝 슬래시 없음).
# 동일 객체가 여기서만 열리면 로컬 썸네일이 바로 살아난다.
# PICKTY_IMAGE_PUBLIC_FALLBACK_BASE=https://pub-xxxxxxxxxxxx.r2.dev

# 로컬 API(localhost:8080)가 R2를 못 읽을 때 네 번째로 시도: 운영 /api/v1/images/file (apiBase 와 달라야 동작)
# PICKTY_IMAGE_FILE_FALLBACK_BASE=https://api.pickty.app
