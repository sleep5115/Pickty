# Vercel 프로덕션 등 빌드 시 주입 (비밀값 없음).
# 로컬 개발은 이 파일이 아니라 .env.local.example → frontend/.env.local 을 쓴다.
NEXT_PUBLIC_API_URL=https://api.pickty.app
NEXT_PUBLIC_SITE_URL=https://pickty.app

# 모바일/LAN에서 `next dev` HMR 허용 시 PC 사설 IP(호스트명만, 포트 없음). 예: 192.168.x.x — 레포에 고정 IP 커밋 금지
# NEXT_DEV_ALLOWED_ORIGIN=<YOUR_LAN_IP>

# R2 커스텀 도메인 외 추가 호스트가 있으면 쉼표 구분(선택)
# NEXT_PUBLIC_PICKTY_IMAGE_HOSTS=
